# InSeoul 환경변수.
#
# ⚠️ 보안 규칙
#   - `VITE_` prefix 환경변수는 Vite 가 클라이언트 빌드 산출물에 inline 한다.
#     사용자가 브라우저에서 source 탭으로 열면 그대로 보인다.
#   - 따라서 API 키 같은 민감 정보는 절대로 VITE_ prefix 로 두지 말 것.
#   - 공개 호스트 URL, 토글 플래그 같은 비-민감 값만 VITE_ 사용.
#
# .env.local 에서 사용자별 비밀 값을 설정한다 (.gitignore 보호됨).

# ─── On-device AI ────────────────────────────────────────────────────────

# LLM 백엔드 선택: 'ollama' | 'mediapipe' | 'none' | (미설정).
# - ollama:    로컬 Ollama 데몬 사용 (HTTP `localhost:11434`). `ollama pull gemma3:4b` 필요.
# - mediapipe: 브라우저 내 MediaPipe Web LLM (.task 파일 다운로드, WebGPU 필수).
# - none:      LLM 비활성. UI 는 템플릿 응답만 제공.
# - 미설정:    VITE_GEMMA_MODEL_URL 이 있으면 mediapipe, 없으면 none 자동 추론.
VITE_LLM_BACKEND=

# Ollama 데몬 URL. 기본 http://localhost:11434.
# 외부 호스트로 바꾸면 *외부 서버에 사용자 데이터가 전송*된다는 점 주의.
VITE_OLLAMA_URL=http://localhost:11434

# Ollama 모델 태그. `ollama list` 의 NAME 값.
VITE_OLLAMA_MODEL=gemma3:4b

# Gemma 2B IT 4-bit 모델 호스팅 URL (~1.3GB .task 파일). MediaPipe 백엔드 전용.
# 미설정 시 mediapipe 백엔드는 모델 로드 실패 → 템플릿 폴백.
# 권장: HuggingFace 또는 Kaggle CDN. CORS 허용 필수. 공개 URL이라 VITE_ 사용 OK.
# 예: https://your-cdn.example.com/gemma-2b-it-gpu-int4.task
VITE_GEMMA_MODEL_URL=

# 로컬 RAG 인덱스 경로. 기본값: /knowledge/index.json (public/ 에서 빌드 시 생성).
# 일반적으로 변경 불필요.
# VITE_KNOWLEDGE_INDEX_PATH=/knowledge/index.json

# ─── 국토교통부 실거래가 API ───────────────────────────────────────────────
#
# 운영자 전용. 클라이언트 런타임에는 노출 X (VITE_ prefix 없음).
# data.go.kr 발급 인증키 (Encoding 형태 그대로).
# 사용처: scripts/refresh-market.ts (Node), scripts/smoke-molit.ts.
# 등록: https://www.data.go.kr/data/15126474/openapi.do
DATA_GO_KR_KEY=
